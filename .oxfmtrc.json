{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "ignorePatterns": [
    ".claude/settings.local.json",
    ".claude/worktrees",
    ".vscode",
    "cache",
    "ignore",
    "node_modules",
    "pnpm-lock.yaml",
    "src/examples/experiments",
    "**/*.md"
  ],
  "printWidth": 80,
  "semi": true,
  "sortPackageJson": false,
  "sortImports": {},
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all"
}
