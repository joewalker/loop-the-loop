{
  "name": "loop-the-loop",
  "version": "0.0.1",
  "description": "Framework for running generated prompts through coding agents",
  "author": "Joe Walker <jwalker@mozilla.com>",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "deno compile --sloppy-imports --allow-read --allow-write --allow-run --allow-env --allow-net --output=dist/loop-the-loop src/cli.ts",
    "eslint": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js --cache --cache-location cache/eslint/",
    "format": "oxfmt",
    "lint": "oxlint src",
    "prepare": "node ./node_modules/typescript/bin/tsc --build tsconfig.json",
    "test": "NODE_ENV=test vitest run",
    "tsc": "node ./node_modules/typescript/bin/tsc --build tsconfig.json"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "engines": {
    "node": ">= 22.0"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.126",
    "glob": "13.0.6",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/js": "9.39.2",
    "@types/node": "25.6.0",
    "@typescript-eslint/utils": "8.59.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "nyc": "18.0.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "typescript-eslint": "8.59.1",
    "v8-to-istanbul": "9.3.0",
    "vitest": "4.1.5"
  },
  "license": "UNLICENSED",
  "private": true
}
