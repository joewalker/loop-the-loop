{
  "$schema": "../../schema/loop-the-loop.schema.json",
  "name": "github-issue-triage",
  "agent": "claude-sdk",
  "promptGenerator": [
    "github",
    {
      "github": {
        "tokenEnv": "GITHUB_TOKEN"
      },
      "search": {
        "repository": "octocat/Hello-World",
        "query": "is:open label:bug no:assignee",
        "sort": "updated",
        "order": "desc",
        "maxResults": 5
      },
      "promptTemplate": "Triage {{id}}: {{title}}\nURL: {{url}}\nState: {{state}}\nAuthor: {{author}}\nLabels: {{labels}}\nComment count: {{commentCount}}\n\n{{body}}"
    }
  ],
  "maxPrompts": 2
}
