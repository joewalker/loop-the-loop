{
  "$schema": "https://raw.githubusercontent.com/joewalker/loop-the-loop/refs/heads/main/schema/loop-the-loop.schema.json",
  "name": "quality-check",
  "agent": [
    "claude-sdk",
    {
      "allowedTools": [
        "Glob",
        "Grep",
        "Read",
        "Bash(codex --help)",
        "Bash(codex help *)",
        "Bash(jq *)",
        "Bash(git diff *)",
        "Bash(gh issue *)",
        "Bash(gh label list *)",
        "Bash(ls *)",
        "Bash(node --version *)",
        "Bash(pnpm config *)",
        "Bash(pnpm format *)",
        "Bash(pnpm lint *)",
        "Bash(pnpm list *)",
        "Bash(pnpm ls *)",
        "Bash(pnpm pack *)",
        "Bash(pnpm test *)",
        "Bash(pnpm tsc *)",
        "Bash(pnpm view *)",
        "Bash(pnpm whoami *)",
        "Bash(pnpm why *)",
        "mcp__ide__*",
        "mcp__mdn__*",
        "WebFetch(domain:api.github.com)",
        "WebFetch(domain:developer.mozilla.org)",
        "WebFetch(domain:developers.openai.com)",
        "WebFetch(domain:docs.anthropic.com)",
        "WebFetch(domain:docs.github.com)",
        "WebSearch"
      ]
    }
  ],
  "allowSourceUpdate": true,
  "promptGenerator": [
    "per-file",
    {
      "promptTemplate": "{{include:prompt.md}}",
      "filePattern": "src/**/*.ts",
      "excludePatterns": ["**/__test__/**", "**/*.test.ts", "**/examples/**"]
    }
  ]
}
